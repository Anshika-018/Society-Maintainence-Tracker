# Server Port
PORT=5000

# Database Configuration
# Set to 'auto' to automatically spin up a local embedded MongoDB with persistence.
# Alternatively, set to a standard URI e.g. mongodb://localhost:27017/society-tracker or MongoDB Atlas URI
MONGODB_URI=auto

# JWT Authentication
JWT_SECRET=supersecretjwtkey_change_in_production

# Business Rules
OVERDUE_THRESHOLD_DAYS=7

# Email Configuration (Nodemailer)
# By default, Ethereal test mail account will be generated if credentials are left empty.
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@Society Maintainence Tracker-society.com
