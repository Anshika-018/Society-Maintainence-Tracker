# Society Maintenance Tracker — Environment Variables Configuration
# Copy this file to `backend/.env` to customize your local configuration.

# Server Port
PORT=5000

# Database Configuration
# Set to 'auto' to automatically spin up a local embedded MongoDB with persistence (zero-config).
# Alternatively, set to a standard URI (e.g., mongodb://localhost:27017/society-tracker or a MongoDB Atlas URI)
MONGODB_URI=auto

# JWT Authentication Secret
JWT_SECRET=supersecretjwtkey_change_in_production

# Business Rules
OVERDUE_THRESHOLD_DAYS=7

# Email Configuration (Nodemailer)
# If left empty, an automatic Ethereal test mail account will be generated.
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@society-tracker.com
